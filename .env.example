# Database Configuration
DATABASE_URL=./db/finance.db
DATABASE_PATH=./db

# Backup Configuration
BACKUP_PATH=./backups
BACKUP_SCHEDULE="0 0 * * 0"  # Every Sunday at midnight (cron format)
BACKUP_RETENTION_DAYS=90      # 3 months

# Drizzle Studio Configuration
STUDIO_HOST=0.0.0.0
STUDIO_PORT=4983

# Application Configuration
NODE_ENV=development
LOG_LEVEL=info
