# Database Configuration
DATABASE_URL=./db/finance.db
DATABASE_PATH=./db
DATABASES_CONFIG=./databases.config.json

# Backup Configuration
BACKUP_PATH=./db/backups      # Backups stored within database directory
BACKUP_SCHEDULE="0 0 * * 0"   # Every Sunday at midnight (cron format)
BACKUP_RETENTION_DAYS=90      # 3 months

# Drizzle Studio Configuration
STUDIO_HOST=0.0.0.0
STUDIO_PORT=4983

# Application Configuration
NODE_ENV=development
LOG_LEVEL=info

# Pocket Money Configuration
POCKET_MONEY_SCHEDULE="0 9 * * 0"    # Every Sunday at 9:00 AM (cron format)
POCKET_MONEY_WEEKLY_AMOUNT=500       # $5.00 in cents
POCKET_MONEY_ENABLED=true            # Enable/disable pocket money job
